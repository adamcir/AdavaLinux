CONFIG_EXT2_FS=y
CONFIG_PATA_ATIIXP=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_VT_CONSOLE=y
CONFIG_VGA_CONSOLE=y
CONFIG_DRM=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_VIRTIO_GPU=y
# Disable VMware/Hyper-V guest modules to avoid vmw_vmci/vmbus warnings
CONFIG_VMWARE_VMCI=n
CONFIG_HYPERV=n
CONFIG_HYPERVISOR_GUEST=n
